<?xml version="1.0"?>
<ComponentManager>
	<Component name="GameManager" class="net.sf.rails.game.specific._1817.GameManager_1817">
		<Game name="1817"/>
		<GameParameters>
			<Parameter name="CanAnyCompanyHoldOwnShares" value="yes"/>
			<PlayerShareLimit percentage="60"></PlayerShareLimit>
			<BankPoolLimit percentage="50"/>
			<StockRound class="net.sf.rails.game.specific._1817.StockRound_1817">
				<NoSaleInFirstSR/>
			</StockRound>
			<OperatingRound class="net.sf.rails.game.specific._1817.OperatingRound_1817">
				<EmergencyTrainBuying mustBuyCheapestTrain="no" mayBuyFromCompany="yes"/>
			</OperatingRound>
		</GameParameters>
		<EndOfGame>
			<Bankruptcy/>
			<BankBreaks limit="0" finish="setOfORs"/>
		</EndOfGame>
	</Component>

	<Component name="PlayerManager" class="net.sf.rails.game.PlayerManager">
		<Players number="3" cash="420" certLimit="21"/>
		<Players number="4" cash="315" certLimit="16"/>
		<Players number="5" cash="252" certLimit="13"/>
		<Players number="6" cash="210" certLimit="11"/>
		<Players number="7" cash="180" certLimit="9"/>
	</Component>

	<Component name="Bank" class="net.sf.rails.game.financial.Bank">
		<Bank amount="9999999"/>
		<Money format="@"/>
	</Component>

	<Component name="TileManager" class="net.sf.rails.game.TileManager" file="TileSet.xml"/>
	<Component name="Map" class="net.sf.rails.game.MapManager" file="Map.xml"/>
	<Component name="CompanyManager" class="net.sf.rails.game.CompanyManager" file="CompanyManager.xml"/>
	<Component name="StockMarket" class="net.sf.rails.game.specific._1817.StockMarket_1817" file="StockMarket.xml"/>

	<Component name="TrainManager" class="net.sf.rails.game.TrainManager">
		<Defaults>
			<Reach base="stops" countTowns="yes"/>
			<Score towns="yes"/>
		</Defaults>
		<TrainType name="2" majorStops="2" cost="100" quantity="-1" />
		<TrainType name="2+" majorStops="2" cost="100" quantity="4" />
		<TrainType name="3" majorStops="3" cost="250" quantity="12">
			<NewPhase phaseName="3"/>
		</TrainType>
		<TrainType name="4" majorStops="4" cost="400" quantity="8">
			<NewPhase phaseName="4"/>
		</TrainType>
		<TrainType name="5" majorStops="5" cost="600" quantity="5">
			<NewPhase phaseName="5"/>
		</TrainType>
		<TrainType name="6" majorStops="6" cost="750" quantity="4">
			<NewPhase phaseName="6"/>
		</TrainType>
		<TrainType name="7" majorStops="7" cost="900" quantity="3">
			<NewPhase phaseName="7"/>
		</TrainType>
		<TrainType name="8" majorStops="8" cost="1100" quantity="999">
			<NewPhase phaseName="8"/>
		</TrainType>
	</Component>



<Component name="PhaseManager" class="net.sf.rails.game.PhaseManager">
		<Phase name="2">
			<Tiles colour="yellow"/>
			<Trains limitStep="1"/>
			<OffBoardRevenue step="1"/>
		</Phase>
		<Phase name="3">
			<Tiles colour="yellow,green"/>
			<OffBoardRevenue step="2"/>
		</Phase>
		<Phase name="4">
			<Tiles colour="yellow,green"/>
			<Trains rusted="2" limitStep="2"/>
			<OffBoardRevenue step="2"/>
		</Phase>
		<Phase name="5">
			<Tiles colour="yellow,green,brown"/>
			<OffBoardRevenue step="3"/>
		</Phase>
		<Phase name="6">
			<Tiles colour="yellow,green,brown"/>
			<Trains rusted="3" limitStep="3"/>
			<OffBoardRevenue step="3"/>
		</Phase>
		<Phase name="7">
			<Tiles colour="yellow,green,brown,gray"/>
			<OffBoardRevenue step="4"/>
		</Phase>
		<Phase name="8">
			<Tiles colour="yellow,green,brown,gray"/>
			<Trains rusted="4"/>
			<OffBoardRevenue step="4"/>
		</Phase>
	</Component>



	<Component name="RevenueManager" class="net.sf.rails.algorithms.RevenueManager">
		<Modifier class="net.sf.rails.game.specific._1817.CoalMineModifier_1817"/>
		<Modifier class="net.sf.rails.game.specific._1817.BridgeModifier_1817"/>
	</Component>
</ComponentManager>